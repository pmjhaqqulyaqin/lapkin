# =============================================
# LKD Production Environment Variables
# =============================================
# PENTING: Ganti nilai-nilai di bawah ini sebelum deploy ke VPS!
# File ini TIDAK boleh di-commit ke Git.
# =============================================

# Password PostgreSQL (ganti dengan password kuat)
LKD_DB_PASSWORD=lkd_secure_password_2026

# JWT Secret (ganti dengan string acak yang panjang)
LKD_JWT_SECRET=lkd-jwt-secret-change-me-in-production

# CORS Origin (domain frontend, gunakan * untuk development)
CORS_ORIGIN=*
